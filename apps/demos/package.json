{
  "name": "@vp-tw/likftc-demos",
  "version": "1.0.0-alpha.0",
  "private": true,
  "type": "module",
  "exports": {
    "./motion": "./src/shared/motion.ts",
    "./number-flow": "./src/shared/number-flow.ts",
    "./number-flow.css": "./src/shared/number-flow.css",
    "./scenario": "./src/shared/scenario.ts"
  },
  "scripts": {
    "build": "vp build && vp build --config vite.qwik.config.ts",
    "check:angular": "pnpm --filter @vp-tw/likftc exec ngc -p ../../apps/demos/tsconfig.json --noEmit",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "check:vue": "vue-tsc --noEmit -p tsconfig.json",
    "check:types:ts6": "pnpm --workspace-root exec tsc6 --noEmit -p apps/demos/tsconfig.json",
    "check:types:ts7": "pnpm --workspace-root exec tsc --noEmit -p apps/demos/tsconfig.json"
  },
  "dependencies": {
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@fontsource-variable/bricolage-grotesque": "5.2.10",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@nanostores/react": "1.1.0",
    "@preact/signals": "2.9.3",
    "@qwik.dev/core": "2.0.0-beta.36",
    "@tanstack/react-store": "0.11.0",
    "@tanstack/store": "0.11.0",
    "@vp-tw/likftc": "workspace:*",
    "@vp-tw/likftc-qwik": "workspace:*",
    "@xstate/react": "6.1.0",
    "alien-signals": "3.2.1",
    "jotai": "2.20.1",
    "nanoid": "6.0.0",
    "nanostores": "1.4.0",
    "pinia": "3.0.4",
    "preact": "10.29.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "solid-js": "1.9.14",
    "svelte": "5.56.4",
    "vue": "3.5.39",
    "xstate": "5.32.4",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "svelte-check": "4.7.2",
    "typescript": "5.9.3",
    "vite-plugin-solid": "2.11.12",
    "vue-tsc": "3.3.7"
  }
}
