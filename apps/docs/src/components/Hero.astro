---
import FilterVortexStage from "./FilterVortexStage.astro";

const frameworks = [
  ["React", "/likftc/frameworks/react/"],
  ["Preact", "/likftc/frameworks/preact/"],
  ["Vue", "/likftc/frameworks/vue/"],
  ["Svelte", "/likftc/frameworks/svelte/"],
  ["Solid", "/likftc/frameworks/solid/"],
  ["Angular", "/likftc/frameworks/angular/"],
  ["Web Components", "/likftc/frameworks/web-components/"],
  ["Qwik β", "/likftc/frameworks/qwik/"],
] as const;
---

<section class="filter-vortex-hero" aria-labelledby="_top">
  <div class="filter-vortex-copy">
    <h1 id="_top">
      <span class="filter-vortex-title-context">Filtered out.</span>
      <span class="filter-vortex-title-result">Found again.</span>
    </h1>
    <p class="filter-vortex-lede">Fresh transition keys for list items that leave and return.</p>
    <div class="filter-vortex-actions">
      <a class="filter-vortex-primary" href="/likftc/getting-started/installation/">
        Start integrating <span aria-hidden="true">↗</span>
      </a>
      <a class="filter-vortex-secondary" href="/likftc/getting-started/comparison/">
        See the failure mode <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
  <FilterVortexStage />
</section>

<nav class="home-framework-rail" aria-label="Supported frameworks">
  {frameworks.map(([label, href]) => <a href={href}>{label}</a>)}
</nav>

<style>
  .filter-vortex-hero {
    background: #171713;
    color: #f2eee4;
    isolation: isolate;
    margin: 0 calc(50% - 50vw) !important;
    min-height: max(48rem, calc(100svh - var(--sl-nav-height)));
    overflow: hidden;
    position: relative;
    width: 100vw;
  }

  .filter-vortex-copy {
    inset: 12% auto auto 4%;
    margin: 0 !important;
    max-width: 44rem;
    pointer-events: none;
    position: absolute;
    z-index: 8;
  }

  .filter-vortex-hero h1,
  .filter-vortex-lede,
  .filter-vortex-actions {
    margin: 0;
  }

  .filter-vortex-hero h1 {
    color: #f2eee4;
    font-family: var(--font-display);
    font-size: clamp(4rem, 9vw, 6rem);
    font-variation-settings: "wdth" 78;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.78;
  }

  .filter-vortex-title-context,
  .filter-vortex-title-result {
    backdrop-filter: blur(10px);
    background: rgb(242 238 228 / 9%);
    display: block;
    line-height: 0.84;
    padding: 0.06em 0.12em 0.1em;
    white-space: nowrap;
    width: fit-content;
  }

  .filter-vortex-title-result {
    color: #ff6f55;
    font-variation-settings: "wdth" 98;
    white-space: nowrap;
  }

  .filter-vortex-lede {
    backdrop-filter: blur(10px);
    background: rgb(23 23 19 / 70%);
    border: 1px solid rgb(217 255 67 / 45%);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    line-height: 1.5;
    margin-top: 2rem;
    max-width: 35rem;
    padding: 0.72rem 0.9rem;
    width: fit-content;
  }

  .filter-vortex-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 2.2rem;
    pointer-events: auto;
    width: fit-content;
  }

  .filter-vortex-primary,
  .filter-vortex-secondary {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 650;
    letter-spacing: 0.035em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .filter-vortex-primary {
    align-items: center;
    background: #f2eee4;
    box-shadow: 0.4rem 0.4rem 0 #d9ff43;
    color: #171713;
    display: inline-flex;
    gap: 1.8rem;
    min-height: 44px;
    padding: 0.95rem 1.15rem;
    transition:
      translate 140ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 140ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .filter-vortex-primary:not([aria-disabled="true"]):hover {
    background: #d9ff43;
    box-shadow: 0.18rem 0.18rem 0 #d9ff43;
    translate: 0.22rem 0.22rem;
  }

  .filter-vortex-primary:not([aria-disabled="true"]):active {
    background: #ff6f55;
    box-shadow: none;
    translate: 0.4rem 0.4rem;
  }

  .filter-vortex-secondary {
    color: #f2eee4;
    min-height: 44px;
    padding-block: 0.75rem;
    text-decoration: underline;
    text-decoration-color: #ff6f55;
    text-decoration-thickness: 0.16rem;
    text-underline-offset: 0.3rem;
  }

  .filter-vortex-primary:focus-visible,
  .filter-vortex-secondary:focus-visible {
    outline: 2px solid #d9ff43;
    outline-offset: 4px;
  }

  .filter-vortex-secondary:not([aria-disabled="true"]):hover {
    color: #d9ff43;
  }

  .filter-vortex-secondary:not([aria-disabled="true"]):active {
    color: #ff9a84;
  }

  .filter-vortex-primary[aria-disabled="true"],
  .filter-vortex-secondary[aria-disabled="true"] {
    color: #aaa59a;
    cursor: not-allowed;
  }

  .filter-vortex-primary[aria-disabled="true"] {
    background: #393934;
    box-shadow: none;
  }

  .filter-vortex-secondary[aria-disabled="true"] {
    text-decoration-style: dotted;
  }

  .home-framework-rail {
    align-items: center;
    border-block: 1px solid var(--brand-line);
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin: 0 calc(50% - 50vw) !important;
    overflow: hidden;
    padding: 0.9rem 1rem;
    white-space: nowrap;
    width: 100vw;
  }

  .home-framework-rail a {
    align-items: center;
    color: var(--brand-ink);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    font-weight: 650;
    gap: 1rem;
    letter-spacing: 0.08em;
    min-height: 44px;
    text-decoration: none;
    text-transform: uppercase;
  }

  .home-framework-rail a + a::before {
    background: var(--brand-coral);
    border-radius: 50%;
    content: "";
    flex: 0 0 auto;
    height: 0.28rem;
    width: 0.28rem;
  }

  .home-framework-rail a:not([aria-disabled="true"]):hover {
    color: var(--interaction-hover);
  }

  .home-framework-rail a:not([aria-disabled="true"]):active {
    color: var(--interaction-active);
  }

  .home-framework-rail a:focus-visible {
    outline: 2px solid var(--interaction-focus);
    outline-offset: 3px;
  }

  .home-framework-rail a[aria-disabled="true"] {
    color: var(--interaction-disabled);
    cursor: not-allowed;
  }

  @media (max-width: 50rem) {
    .filter-vortex-copy {
      inset: 4.75rem 1rem auto;
    }

    .filter-vortex-lede {
      max-width: 29rem;
    }
  }

  @media (max-width: 30rem) {
    .filter-vortex-hero {
      min-height: max(50rem, calc(100svh - var(--sl-nav-height)));
    }

    .filter-vortex-copy {
      inset-inline: 0.8rem;
    }

    .filter-vortex-hero h1 {
      font-size: clamp(3rem, 15vw, 4.8rem);
    }

    .filter-vortex-title-context {
      font-size: 0.58em;
      letter-spacing: -0.015em;
      line-height: 1;
      margin-bottom: 0.2rem;
      white-space: normal;
    }

    .filter-vortex-title-result {
      white-space: normal;
    }

    .filter-vortex-lede {
      font-size: 1rem;
      margin-top: 1.4rem;
    }

    .filter-vortex-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 1.4rem;
    }

    .home-framework-rail {
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: thin;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .filter-vortex-primary {
      transition: none;
    }
  }
</style>
